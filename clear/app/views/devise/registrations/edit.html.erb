<div class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-6xl items-center justify-center px-4 py-8 md:px-6 md:py-12">
  <div class="w-full max-w-md rounded-3xl border border-zinc-800 bg-zinc-900/40 p-5 md:p-8 shadow-2xl shadow-black/30 backdrop-blur-md">
    <div class="mb-6 md:mb-8">
      <h1 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-50">Edit account</h1>
      <p class="mt-1 text-sm text-zinc-500">Update your email or password.</p>
    </div>

    <%= form_for(resource,
          as: resource_name,
          url: registration_path(resource_name),
          html: { method: :put, data: { turbo: false } }) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-5">
        <div>
          <%= f.label :email, class: "text-sm font-medium text-zinc-300" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "mt-2 w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 backdrop-blur-sm transition-colors duration-200 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20",
                placeholder: "your email" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="text-sm text-amber-300">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
        <% end %>

        <div>
          <div class="flex items-baseline justify-between">
            <%= f.label :password, class: "text-sm font-medium text-zinc-300" %>
            <span class="text-xs text-zinc-600">leave blank to keep current</span>
          </div>
          <%= f.password_field :password,
                autocomplete: "new-password",
                class: "mt-2 w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 backdrop-blur-sm transition-colors duration-200 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20",
                placeholder: "new password" %>
          <% if @minimum_password_length %>
            <p class="mt-1 text-xs text-zinc-600"><%= @minimum_password_length %>+ characters</p>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "text-sm font-medium text-zinc-300" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                class: "mt-2 w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 backdrop-blur-sm transition-colors duration-200 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20",
                placeholder: "confirm new password" %>
        </div>

        <div>
          <%= f.label :current_password, class: "text-sm font-medium text-zinc-300" %>
          <p class="mt-0.5 text-xs text-zinc-600">We need your current password to confirm changes</p>
          <%= f.password_field :current_password,
                autocomplete: "current-password",
                class: "mt-2 w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 backdrop-blur-sm transition-colors duration-200 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20",
                placeholder: "current password" %>
        </div>

        <%= f.submit "Update",
              class: "studs-btn-accent mt-3 !w-full !rounded-xl !py-2.5 !text-sm" %>
      </div>
    <% end %>

    <div class="mt-6 pt-4" style="border-top: 1px solid var(--studs-divider, #27272a);">
      <p class="text-sm font-medium text-zinc-400">Cancel my account</p>
      <p class="mt-1 text-xs text-zinc-600">
        <%= button_to "Delete my account", registration_path(resource_name),
              data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
              method: :delete,
              class: "text-red-400 hover:text-red-300 underline transition-colors" %>
      </p>
    </div>

    <%= render "devise/shared/links" %>
  </div>
</div>
