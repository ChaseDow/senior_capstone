<div class="h-full w-full">
  <div class="flex items-center justify-between px-4 py-3 studs-topbar">
    <div class="min-w-0">
      <div class="h-4 w-28 rounded animate-pulse" style="background-color: var(--studs-panel-hover);"></div>
      <div class="mt-2 h-3 w-44 rounded animate-pulse" style="background-color: var(--studs-panel-bg);"></div>
    </div>
    <div class="h-7 w-16 rounded-xl animate-pulse" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);"></div>
  </div>
  <div class="px-3 py-3 space-y-2">
    <% 6.times do %>
      <div class="rounded-2xl border p-3" style="border-color: var(--studs-border); background-color: var(--studs-panel-bg-2);">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full animate-pulse" style="background-color: var(--studs-panel-hover);"></div>
              <div class="h-4 w-44 rounded animate-pulse" style="background-color: var(--studs-panel-hover);"></div>
            </div>
            <div class="mt-2 h-3 w-28 rounded animate-pulse" style="background-color: var(--studs-panel-bg);"></div>
            <div class="mt-2 h-3 w-36 rounded animate-pulse" style="background-color: var(--studs-panel-bg);"></div>
          </div>
          <div class="h-7 w-14 rounded-xl animate-pulse" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);"></div>
        </div>
      </div>
    <% end %>
  </div>
</div>