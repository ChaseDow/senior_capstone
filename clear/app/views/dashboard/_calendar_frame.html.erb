<%= turbo_frame_tag "dashboard_calendar", class: "block h-full min-h-0" do %>
  <%= render "dashboard/calendar",
       events: events,
       start_date: start_date,
       draft: local_assigns[:draft],
       month_occurrences: local_assigns[:month_occurrences],
       month_date: local_assigns[:month_date] %>
<% end %>
