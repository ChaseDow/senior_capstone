<% content_for :page_title, "Syllabi" %>
<% content_for :page_subtitle, "Uploaded syllabi" %>

<div class="rounded-2xl p-6" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <div class="mb-5 flex items-center justify-between gap-3">
    <div>
      <div class="text-base font-semibold text-zinc-100">New syllabus</div>
      <div class="text-sm text-zinc-500">Upload one file and we’ll parse it into a course preview.</div>
    </div>
    <%= link_to syllabuses_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back
    <% end %>
  </div>

  <%= form_with model: @syllabus, html: { multipart: true }, class: "space-y-5", id: "syllabus-form" do |f| %>
    <% if @syllabus.errors.any? %>
      <div class="rounded-2xl p-4 text-red-200"
           style="border: 1px solid rgba(239,68,68,0.3); background-color: rgba(127,29,29,0.2);">
        <p class="font-medium">Please fix the following:</p>
        <ul class="mt-2 list-disc pl-6 text-sm">
          <% @syllabus.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% input_classes = "mt-1 w-full rounded-2xl px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-500 bg-zinc-950/60 border focus:outline-none focus:ring-2 transition-all duration-150" %>
    <% input_style = "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);" %>
    <% label_classes = "block text-[10px] font-bold uppercase tracking-widest text-zinc-300" %>
    <% label_style = "color: var(--studs-accent); opacity: 0.8;" %>

    <div>
      <%= f.label :title, class: label_classes, style: label_style %>
      <%= f.text_field :title, class: input_classes, style: input_style, placeholder: "e.g. BISC 1303 - Biological Principles, MATH 2413 - Calculus I" %>
    </div>

  
      <%= f.label :file, "Upload file", class: label_classes, style: label_style %>
      <div class="mt-1 filepond-host" data-controller="filepond">
        <%= f.file_field :file,
              accept: ".pdf,.doc,.docx",
              class: "filepond-input",
              data: { filepond_target: "input" } %>
      <p class="mt-2 text-xs text-zinc-500">
        Accepted formats: PDF, DOC, or DOCX.
      </p>
    </div>


    <div class="flex items-center gap-2 pt-4" style="border-top: 1px solid var(--studs-divider);">
      <%= render Studs::PrimaryButtonComponent.new(
            label: "Upload Syllabus",
            type: "submit",
            color: :emerald
          ) %>
      <%= link_to "Cancel", syllabuses_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } %>
    </div>
  <% end %>
</div>
