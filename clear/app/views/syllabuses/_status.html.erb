<div class="flex items-center gap-2">
  <% if syllabus.course_id.present? %>
    <%= link_to "Go to Course",
                course_path(syllabus.course_id),
                class: "studs-btn-accent",
                data: { turbo_frame: "_top" } %>

  <% elsif syllabus.parse_status == "processing" %>
    <button type="button" class="studs-nav-btn cursor-not-allowed opacity-60" disabled aria-disabled="true">
      Parsing...
    </button>

  <% elsif syllabus.parse_status == "queued" %>
    <button type="button" class="studs-nav-btn cursor-not-allowed opacity-60" disabled aria-disabled="true">
      Queued...
    </button>

  <% elsif syllabus.parse_status == "failed" %>
    <%= link_to "Failed",
                create_course_syllabus_path(syllabus),
                class: "studs-btn-accent",
                data: { turbo_method: :post, turbo_frame: "_top" } %>

  <% elsif syllabus.course_draft.present? %>
    <%= link_to "Review",
                course_preview_syllabus_path(syllabus),
                class: "studs-btn-accent",
                data: { turbo_frame: "_top" } %>

  <% else %>
    <%= link_to "Create course",
                create_course_syllabus_path(syllabus),
                class: "studs-btn-accent",
                data: { turbo_method: :post, turbo_frame: "_top" } %>
  <% end %>
</div>
