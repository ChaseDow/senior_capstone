<div class="mx-auto max-w-md">
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-zinc-100">Change Password</h1>
    <p class="mt-1 text-sm text-zinc-500">Set a new password for <span class="text-zinc-300"><%= @user.email %></span></p>
  </div>

  <% if flash[:alert] %>
    <div class="mb-4 rounded-xl border border-rose-800 bg-rose-950/40 px-4 py-3 text-sm text-rose-300">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if @user.errors.any? %>
    <div class="mb-4 rounded-xl border border-rose-800 bg-rose-950/40 px-4 py-3 text-sm text-rose-300">
      <% @user.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-6">
    <%= form_with model: @user, url: update_password_admin_user_path(@user), method: :patch do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :password, "New password", class: "block text-sm font-medium text-zinc-300" %>
          <div class="relative mt-2">
            <%= f.password_field :password,
                  id: "admin-new-password",
                  autocomplete: "new-password",
                  class: "w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-colors duration-200",
                  placeholder: "new password" %>
            <button type="button"
              data-password-toggle
              data-target="admin-new-password"
              class="absolute right-3 top-1/2 -translate-y-1/2 rounded-md p-1 text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60 focus:outline-none transition">
              <span data-show>
                <%= icon "eye-stroke-rounded", class: "h-5 w-5 text-zinc-400" %>
              </span>
              <span data-hide class="hidden">
                <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 text-zinc-400" %>
              </span>
            </button>
          </div>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-zinc-300" %>
          <div class="relative mt-2">
            <%= f.password_field :password_confirmation,
                  id: "admin-confirm-password",
                  autocomplete: "new-password",
                  class: "w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-colors duration-200",
                  placeholder: "re-type new password" %>
            <button type="button"
              data-password-toggle
              data-target="admin-confirm-password"
              class="absolute right-3 top-1/2 -translate-y-1/2 rounded-md p-1 text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60 focus:outline-none transition">
              <span data-show>
                <%= icon "eye-stroke-rounded", class: "h-5 w-5 text-zinc-400" %>
              </span>
              <span data-hide class="hidden">
                <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 text-zinc-400" %>
              </span>
            </button>
          </div>
        </div>

        <div class="flex gap-3 pt-2">
          <%= f.submit "Update password",
                class: "studs-btn-accent !rounded-xl !py-2.5 !text-sm !flex-1 !justify-center" %>
          <%= link_to "Cancel", admin_users_path,
                class: "studs-nav-btn !rounded-xl !py-2.5 !text-sm !flex-1 !justify-center" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
