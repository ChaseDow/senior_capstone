<% is_user = (m["role"].to_s.downcase == "user") %>
<% raw_text = m["content"].to_s %>
<% animate = local_assigns.fetch(:animate, false) %>
<div class="flex items-start <%= is_user ? "justify-end" : "justify-start" %> ai-chat-pop">
  <div
    class="self-start inline-flex flex-col max-w-[80%] rounded-2xl px-4 py-3 text-sm leading-relaxed"
    style="<%= is_user ?
      "background-color: color-mix(in srgb, var(--studs-accent) 15%, transparent);
       border: 1px solid color-mix(in srgb, var(--studs-accent) 30%, transparent);
       color: #f0fdf4;" :
      "background-color: var(--studs-panel-bg-2);
       border: 1px solid var(--studs-border);
       color: #f4f4f5;" %>"
  >
    <div class="mb-1.5">
      <span class="text-[10px] font-bold uppercase tracking-widest"
            style="color: <%= is_user ? "var(--studs-accent)" : "color-mix(in srgb, var(--studs-accent) 60%, #a1a1aa)" %>;">
        <%= is_user ? "You" : "Assistant" %>
      </span>
    </div>
    <% if is_user %>
      <div class="whitespace-normal break-words">
        <%= h(raw_text.strip) %>
      </div>
    <% elsif animate %>
      <div
        data-controller="typewriter"
        data-typewriter-text-value="<%= raw_text %>"
        class="prose prose-invert prose-sm max-w-none whitespace-pre-wrap"
      ></div>
    <% else %>
      <div class="prose prose-invert prose-sm max-w-none whitespace-pre-wrap break-words"><%= h(raw_text) %></div>
    <% end %>
  </div>
</div>
