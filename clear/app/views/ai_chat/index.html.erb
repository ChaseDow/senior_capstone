<% content_for :page_title, "AI Chat" %>
<% content_for :page_subtitle, "Consult with an AI" %>
<div class="h-full min-h-0 flex flex-col"
     data-controller="full-height"
     style="background-color: var(--studs-panel-bg-2);">
  <!-- Header -->
  <div class="shrink-0 flex items-center justify-between px-4 py-3 md:px-6 md:py-4 backdrop-blur"
       style="border-bottom: 1px solid var(--studs-border); background-color: var(--studs-panel-header);">
    <div>
      <h1 class="text-base font-semibold text-zinc-100">Assistant</h1>
      <p class="text-xs text-zinc-400 mt-0.5">Ask questions, explore scenarios, and compare schedule what-ifs.</p>
    </div>
    <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium"
          style="border: 1px solid rgba(34, 197, 94, 0.3);
                 background-color: rgba(34, 197, 94, 0.1);
                 color: #86efac;">
      <span class="h-1.5 w-1.5 rounded-full"
            style="background-color: #22c55e;
                   box-shadow: 0 0 8px rgba(34, 197, 94, 0.7);"></span>
      Online
    </span>
  </div>
  <!-- Usage -->
  <div class="shrink-0 px-6 pt-3">
    <%= render "ai_chat/usage", rate: @rate || { rpm: 0, rpm_limit: 10, rpd: 0, rpd_limit: 250 } %>
  </div>
  <!-- Flash -->
  <div id="ai_chat_flash" class="shrink-0 px-4 md:px-6 pt-3 empty:hidden">
    <% if flash[:alert].present? %>
      <div class="rounded-2xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-200">
        <%= flash[:alert] %>
      </div>
    <% end %>
  </div>
  <!-- Messages -->
  <div
    id="ai_chat_messages"
    class="flex-1 min-h-0 overflow-y-auto px-4 py-4 md:px-6 md:py-5 flex flex-col justify-start gap-3 scrollbars"
  >
    <% @messages.each do |m| %>
      <%= render "ai_chat/message", m: m %>
    <% end %>
  </div>
  <!-- Composer -->
  <div class="shrink-0 px-4 py-3 md:px-6 md:py-4 backdrop-blur"
       style="border-top: 1px solid var(--studs-border); background-color: var(--studs-panel-header);">
    <%= form_with url: ai_chat_index_path,
      method: :post,
      class: "flex items-center gap-3",
      data: {
        turbo: true,
        controller: "chat",
        action: "turbo:submit-start->chat#submit turbo:submit-end->chat#reset"
      } do %>
      <%= hidden_field_tag :history,
        (@messages || []).to_json,
        id: "ai_chat_history" %>
      <div class="flex-1">
        <%= text_area_tag :content, "",
          id: "ai_chat_input",
          rows: 2,
          placeholder: "Ask a what-if… (Shift+Enter for new line)",
          class: "w-full resize-none rounded-2xl px-4 py-3 text-sm text-zinc-100 placeholder:text-zinc-500 focus:outline-none transition",
          style: "background-color: color-mix(in srgb, var(--studs-panel-bg) 60%, #09090b);
                  border: 1px solid var(--studs-border);",
          data: { action: "keydown->chat#sendOnEnter" } %>
      </div>
      <button type="submit"
              class="shrink-0 inline-flex items-center justify-center rounded-2xl w-11 h-11 transition hover:brightness-110 focus:outline-none"
              style="background-color: var(--studs-accent);
                     box-shadow: 0 0 16px color-mix(in srgb, var(--studs-accent) 40%, transparent);">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 19V5m0 0l-7 7m7-7l7 7"/>
        </svg>
      </button>
    <% end %>
  </div>
</div>