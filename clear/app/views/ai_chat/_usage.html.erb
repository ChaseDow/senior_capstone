<div id="ai_chat_usage" data-controller="ai-usage" data-ai-usage-url-value="<%= usage_ai_chat_index_path %>">
  <%# Per-minute gauge %>
  <% rpm = rate[:rpm] %>
  <% rpm_limit = rate[:rpm_limit] %>
  <% rpm_pct = (rpm.to_f / rpm_limit * 100).clamp(0, 100) %>

  <%# Daily gauge %>
  <% rpd = rate[:rpd] %>
  <% rpd_limit = rate[:rpd_limit] %>
  <% rpd_pct = (rpd.to_f / rpd_limit * 100).clamp(0, 100) %>

  <div class="flex items-center gap-4">
    <%# RPM %>
    <div class="flex items-center gap-2 flex-1">
      <span class="text-[10px] uppercase tracking-wider font-semibold" style="color: #a1a1aa;">min</span>
      <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background-color: rgba(255,255,255,0.1);">
        <div class="h-full rounded-full transition-all duration-500"
             data-ai-usage-target="rpmBar"
             style="width: <%= rpm_pct %>%; background-color: <%= rpm_pct >= 90 ? '#ef4444' : rpm_pct >= 70 ? '#f59e0b' : '#22c55e' %>;"></div>
      </div>
      <span class="text-xs font-medium whitespace-nowrap"
            data-ai-usage-target="rpmText"
            style="color: <%= rpm_pct >= 90 ? '#fca5a5' : rpm_pct >= 70 ? '#fcd34d' : '#86efac' %>;">
        <%= rpm %> / <%= rpm_limit %>
      </span>
    </div>

    <div class="w-px h-4" style="background-color: var(--studs-border);"></div>

    <%# RPD %>
    <div class="flex items-center gap-2 flex-1">
      <span class="text-[10px] uppercase tracking-wider font-semibold" style="color: #a1a1aa;">day</span>
      <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background-color: rgba(255,255,255,0.1);">
        <div class="h-full rounded-full transition-all duration-500"
             data-ai-usage-target="rpdBar"
             style="width: <%= rpd_pct %>%; background-color: <%= rpd_pct >= 90 ? '#ef4444' : rpd_pct >= 70 ? '#f59e0b' : '#22c55e' %>;"></div>
      </div>
      <span class="text-xs font-medium whitespace-nowrap"
            data-ai-usage-target="rpdText"
            style="color: <%= rpd_pct >= 90 ? '#fca5a5' : rpd_pct >= 70 ? '#fcd34d' : '#86efac' %>;">
        <%= rpd %> / <%= rpd_limit %>
      </span>
    </div>
  </div>

  <% if rpd >= rpd_limit %>
    <p class="text-xs mt-1" style="color: #fca5a5;">Daily limit reached. Resets at midnight.</p>
  <% elsif rpm >= rpm_limit %>
    <p class="text-xs mt-1" style="color: #fcd34d;">Per-minute limit reached. Wait a moment.</p>
  <% end %>
</div>
