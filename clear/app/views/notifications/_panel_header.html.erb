<%# locals: (unread_count:) %>
<div>
  <div class="text-sm font-semibold text-zinc-100">Notifications</div>
  <% if unread_count > 0 %>
    <div class="mt-0.5 text-xs text-zinc-400"><%= unread_count %> unread</div>
  <% end %>
</div>
<% if unread_count > 0 %>
  <%= button_to "Mark all read",
        mark_all_read_notifications_path,
        method: :patch,
        class: "text-xs font-medium px-3 py-1.5 rounded-xl border border-white/10 bg-zinc-950/30 hover:bg-white/5 transition text-zinc-300 hover:text-zinc-100 cursor-pointer" %>
<% end %>
