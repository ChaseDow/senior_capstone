<%# locals: (notifications:, unread_count:) %>
<div class="flex flex-col" style="max-height: 28rem;">
  <%# Header %>
  <div id="notifications_panel_header" class="shrink-0 flex items-center justify-between px-4 py-3 studs-topbar">
    <%= render "notifications/panel_header", unread_count: unread_count %>
  </div>

  <%# Body %>
  <div id="notifications_list" class="flex-1 min-h-0 overflow-y-auto px-3 py-3 space-y-2">
    <% if notifications.empty? %>
      <%= render "notifications/empty_state" %>
    <% else %>
      <% notifications.each do |notification| %>
        <% notifiable = notification.notifiable %>
        <% open_path = if notification.category == "assignment_due" && notifiable.is_a?(CourseItem)
             edit_course_course_item_path(notifiable.course, notifiable)
           elsif notification.category == "high_priority" && notifiable.is_a?(Event)
             event_path(notifiable)
           end %>

        <div id="<%= dom_id(notification) %>"
             class="rounded-2xl border px-3 py-3 transition <%= notification.read? ? 'opacity-60' : '' %>"
             style="border-color: var(--studs-border); background-color: var(--studs-panel-header);">
          <div class="flex items-start gap-2.5">
            <%# Read/unread dot %>
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full <%= notification.read? ? 'bg-zinc-600' : 'bg-rose-500' %>"></span>

            <div class="min-w-0 flex-1">
              <div class="text-sm font-medium text-zinc-100 truncate"><%= notification.message %></div>
              <div class="mt-0.5 flex items-center gap-1.5 text-xs text-zinc-400">
                <span><%= notification.created_at.strftime("%-b %-d at %-I:%M %p") %></span>
                <span class="text-zinc-600">•</span>
                <span><%= notification.category.humanize %></span>
              </div>
            </div>

            <% if open_path %>
              <%= link_to "Open", open_path,
                    class: "shrink-0 rounded-xl border border-white/10 px-2.5 py-1 text-xs font-medium text-zinc-300 hover:text-zinc-100 hover:bg-white/5 transition",
                    data: { turbo_frame: "event_drawer", action: "click->drawer#start" } %>
            <% end %>

            <%= button_to notification_path(notification),
                  method: :delete,
                  class: "shrink-0 flex items-center justify-center h-6 w-6 rounded-lg text-zinc-500 hover:text-zinc-200 hover:bg-white/10 transition cursor-pointer",
                  title: "Dismiss" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18M6 6l12 12"/>
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
