<% content_for :page_title, "Import Calendar" %>
<% content_for :page_subtitle, "Import events from an RSS calendar feed" %>

<div class="rounded-2xl p-3 md:p-6" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <!-- URL entry form -->
  <%= form_with url: university_calendar_preview_path, method: :get do |f| %>
    <div class="flex flex-col md:flex-row md:items-center gap-3 mb-4 md:mb-6">
      <%= f.text_field :rss_url,
            value: @rss_url,
            placeholder: "Paste your calendar RSS feed URL…",
            class: "flex-1 rounded-xl border px-3 py-2 text-sm bg-transparent text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-1",
            style: "border-color: var(--studs-border); focus:border-color: var(--studs-accent);" %>
      <%= f.submit "Preview",
            class: "studs-nav-btn cursor-pointer" %>
      <%= link_to "Cancel", events_path, class: "studs-nav-btn" %>
    </div>
  <% end %>

  <% if flash[:alert].present? %>
    <p class="mb-4 text-sm text-red-400"><%= flash[:alert] %></p>
  <% end %>

  <% if @items %>
    <div class="flex items-center justify-between mb-4">
      <p class="text-sm text-zinc-400">
        <%= @items.size %> event(s) found. Events already in your calendar are marked as duplicates.
      </p>
      <% if @items.any? %>
        <%= button_to "Import All New Events", university_calendar_import_path,
              method: :post,
              params: { rss_url: @rss_url },
              class: "inline-flex items-center justify-center rounded-xl px-4 py-2 text-sm font-medium
                      bg-blue-600 text-white hover:bg-blue-500 transition" %>
      <% end %>
    </div>

    <div class="overflow-hidden rounded-2xl" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <% if @items.any? %>
        <% @items.each_with_index do |item, i| %>
          <% key = "#{item[:title].to_s.downcase.strip}|#{item[:starts_at]&.to_date}" %>
          <% duplicate = @existing_keys.include?(key) %>

          <div class="flex items-start justify-between gap-4 p-4 <%= duplicate ? 'opacity-50' : '' %>"
               style="<%= i > 0 ? 'border-top: 1px solid var(--studs-divider);' : '' %>
                      border-left: 4px solid #60A5FA;">
            <div class="min-w-0 flex-1">
              <p class="font-medium text-zinc-100 flex items-center gap-2 flex-wrap">
                <%= item[:title] %>
                <% if duplicate %>
                  <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold"
                        style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover); color: var(--studs-accent);">
                    Already imported
                  </span>
                <% end %>
              </p>
              <p class="mt-1 text-sm text-zinc-400">
                <%= item[:starts_at]&.strftime("%b %d, %Y") %>
                <% if item[:ends_at].present? %>
                  &ndash; <%= item[:ends_at].strftime("%b %d, %Y") %>
                <% end %>
              </p>
              <% if item[:location].present? %>
                <p class="text-sm text-zinc-500">📍 <%= item[:location] %></p>
              <% end %>
              <% if item[:description].present? %>
                <p class="mt-1 text-xs text-zinc-500 line-clamp-2"><%= item[:description] %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="p-8 text-center text-sm text-zinc-400">No events found in this feed.</div>
      <% end %>
    </div>
  <% end %>
</div>
