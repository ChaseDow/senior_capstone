<div id="toast-container" class="fixed top-6 right-6 z-[200] flex flex-col gap-3 pointer-events-none">
  <% if notice.present? %>
    <div data-controller="toast" data-toast-duration-value="4000"
         class="relative pointer-events-auto flex items-start gap-3 rounded-xl border px-4 py-3 text-sm text-zinc-100
                overflow-hidden backdrop-blur-md shadow-lg translate-x-full opacity-0 transition-all duration-300 ease-out min-w-[280px] max-w-[400px]"
         style="border-color: var(--studs-border); background-color: color-mix(in srgb, var(--studs-sidebar-bg) 85%, transparent);">
      <svg class="h-5 w-5 shrink-0 mt-0.5" style="color: var(--studs-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
      <span class="flex-1"><%= notice %></span>
      <button type="button" data-action="toast#dismiss" class="shrink-0 text-zinc-500 hover:text-zinc-200 transition-colors text-lg leading-none">&times;</button>
      <div class="absolute bottom-0 left-0 h-0.5 rounded-full" style="background-color: var(--studs-accent); width: 100%;" data-toast-progress></div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div data-controller="toast" data-toast-duration-value="5000"
         class="relative pointer-events-auto flex items-start gap-3 rounded-xl border border-rose-800/60 px-4 py-3 text-sm text-rose-100
                overflow-hidden backdrop-blur-md shadow-lg translate-x-full opacity-0 transition-all duration-300 ease-out min-w-[280px] max-w-[400px]"
         style="background-color: rgba(76, 5, 25, 0.85);">
      <svg class="h-5 w-5 shrink-0 mt-0.5 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
      </svg>
      <span class="flex-1"><%= alert %></span>
      <button type="button" data-action="toast#dismiss" class="shrink-0 text-rose-400 hover:text-rose-200 transition-colors text-lg leading-none">&times;</button>
      <div class="absolute bottom-0 left-0 h-0.5 rounded-full bg-rose-500" style="width: 100%;" data-toast-progress></div>
    </div>
  <% end %>
</div>
