<% content_for :page_title, "Agenda" %>
<% content_for :page_subtitle, "Upcoming tasks" %>
<% filter_input_style = "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);" %>
<% today = Time.zone.today %>
<% entries = (@paged_agenda_by_date || {})[today] || [] %>
<% active_filters = [params.dig(:q, :term), params[:type], params[:start_date], params[:end_date]].compact.count(&:present?) %>
<% entries_by_date =
  if active_filters.positive?
    (@paged_agenda_by_date || {}).sort_by { |date, _| date }.to_h
  elsif entries.any?
    { today => entries }
  else
    {}
  end %>

<div class="space-y-4">
  <%= form_with url: agenda_index_path,
                method: :get,
                data: {
                  controller: "search",
                  search_target: "form",
                  turbo_frame: "agenda_list"
                },
                html: { class: "space-y-3" } do |f| %>
    <div class="flex flex-wrap items-center gap-2 rounded-2xl p-2"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <div class="min-w-[240px] flex-1">
        <%= render Studs::SearchBarComponent.new(
          name: "q[term]",
          value: params.dig(:q, :term),
          placeholder: "Search by filter option (first button to the right)…",
          class_name: "w-full",
          data: {
            search_target: "input",
            action: "input->search#search keydown->search#submit"
          }
        ) %>
      </div>
      <div class="mx-1 hidden h-5 w-px rounded-full md:block" style="background-color: var(--studs-border);"></div>
      <div class="w-40">
        <%= select_tag "q[field]",
          options_for_select(
            [["Name", "name"], ["Location", "location"], ["Description", "description"]],
            params.dig(:q, :field).presence || "name"
          ),
          class: "w-full rounded-xl border bg-zinc-900/50 px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:ring-2 transition-all",
          style: filter_input_style,
          data: { action: "change->search#search" } %>
      </div>
      <div class="mx-1 hidden h-5 w-px rounded-full md:block" style="background-color: var(--studs-border);"></div>
      <div class="w-36">
        <%= f.select :type,
          options_for_select(
            [["All Types", ""], ["Events", "event"], ["Courses", "course"], ["Course Items", "course_item"]],
            params[:type]
          ),
          {},
          class: "w-full rounded-xl border bg-zinc-900/50 px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:ring-2 transition-all",
          style: filter_input_style,
          data: { action: "change->search#search" } %>
      </div>
      <div class="mx-1 hidden h-5 w-px rounded-full md:block" style="background-color: var(--studs-border);"></div>
      <div class="flex items-center gap-2">
        <%= f.date_field :start_date,
          value: params[:start_date],
          placeholder: "Start",
          class: "h-[38px] w-36 rounded-xl border bg-zinc-900/50 px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:ring-2 transition-all",
          style: filter_input_style,
          data: { action: "change->search#search" } %>
        <span class="text-sm text-zinc-500 font-medium select-none">:</span>
        <%= f.date_field :end_date,
          value: params[:end_date],
          placeholder: "End",
          class: "h-[38px] w-36 rounded-xl border bg-zinc-900/50 px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:ring-2 transition-all",
          style: filter_input_style,
          data: { action: "change->search#search" } %>
      </div>
      <% if active_filters.positive? %>
        <div class="mx-1 hidden h-5 w-px rounded-full md:block" style="background-color: var(--studs-border);"></div>
        <%= link_to "Reset",
          agenda_index_path,
          class: "inline-block rounded-xl border bg-zinc-900/50 px-4 py-2 text-sm font-medium text-zinc-200 hover:bg-zinc-800/50 focus:outline-none transition",
          style: filter_input_style %>
      <% end %>
    </div>
  <% end %>

  <%= turbo_frame_tag "agenda_list" do %>
    <%= render "agenda/list_frame",
      entries_by_date: entries_by_date,
      active_filters: active_filters %>
  <% end %>
</div>
