<%# Person / Personal tab — widget-grid + widget-drawer share this root element. %>

<div data-controller="widget-grid widget-drawer">

  <%# ── GridStack canvas ─────────────────────────────────────────── %>
  <div class="grid-stack" data-widget-grid-target="grid"
       style="min-height:200px;"></div>

  <%# ── FAB ─────────────────────────────────────────────────────── %>
  <button data-action="click->widget-drawer#open"
          style="position:fixed;bottom:24px;right:24px;z-index:100;
                 width:56px;height:56px;border-radius:50%;
                 background:var(--studs-accent,#6366f1);color:white;
                 border:none;font-size:28px;line-height:1;cursor:pointer;
                 box-shadow:0 4px 16px rgba(0,0,0,0.3);"
          aria-label="Add widget">+</button>

  <%# ── Drawer backdrop ────────────────────────────────────────────── %>
  <div data-widget-drawer-target="backdrop"
       data-action="click->widget-drawer#close"
       class="hidden"
       style="position:fixed;inset:0;background:rgba(0,0,0,0.5);
              z-index:200;backdrop-filter:blur(2px);"></div>

  <%# ── Drawer panel ────────────────────────────────────────────────── %>
  <div data-widget-drawer-target="panel"
       style="position:fixed;top:0;right:0;height:100vh;width:400px;
              background:var(--studs-sidebar-bg,#18181b);
              border-left:1px solid var(--studs-border,#3f3f46);
              z-index:300;box-shadow:-4px 0 24px rgba(0,0,0,0.4);
              transform:translateX(100%);transition:transform 0.3s ease;
              overflow-y:auto;display:flex;flex-direction:column;">

    <%# Header %>
    <div style="display:flex;align-items:center;justify-content:space-between;
                padding:16px 20px;border-bottom:1px solid var(--studs-border,#3f3f46);
                flex-shrink:0;">
      <div>
        <div style="font-size:15px;font-weight:600;color:#f4f4f5;">Add Widget</div>
        <div style="font-size:12px;color:#71717a;margin-top:2px;">Click a card to add it to your dashboard</div>
      </div>
      <button data-action="click->widget-drawer#close"
              style="width:32px;height:32px;display:flex;align-items:center;
                     justify-content:center;border-radius:8px;border:none;
                     background:none;color:#71717a;font-size:22px;cursor:pointer;">
        &times;
      </button>
    </div>

    <%# Scrollable body — swapped with config form when a configured card is clicked %>
    <div data-widget-drawer-target="body"
         style="flex:1;overflow-y:auto;padding:16px;display:grid;
                grid-template-columns:1fr 1fr;gap:12px;">

      <%# Line Chart %>
      <div data-action="click->widget-drawer#selectWidget"
           data-widget-type="line"
           data-widget-label="Line Chart"
           data-widget-w="4" data-widget-h="3"
           style="border:1px solid var(--studs-border,#3f3f46);border-radius:10px;
                  padding:14px;cursor:pointer;transition:border-color 0.15s,background 0.15s;
                  background:var(--studs-panel-bg,#1e1e2e);"
           onmouseover="this.style.borderColor='var(--studs-accent,#6366f1)'"
           onmouseout="this.style.borderColor='var(--studs-border,#3f3f46)'">
        <svg viewBox="0 0 60 30" style="width:100%;height:40px;margin-bottom:8px;">
          <polyline points="4,23 14,14 24,18 34,8 44,13 56,4"
                    fill="none" stroke="var(--studs-accent,#6366f1)"
                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div style="font-size:12px;font-weight:600;color:#e4e4e7;">Line Chart</div>
        <div style="font-size:10px;color:#71717a;margin-top:2px;">Time series trend</div>
      </div>

      <%# Bar Chart %>
      <div data-action="click->widget-drawer#selectWidget"
           data-widget-type="bar"
           data-widget-label="Bar Chart"
           data-widget-w="4" data-widget-h="3"
           style="border:1px solid var(--studs-border,#3f3f46);border-radius:10px;
                  padding:14px;cursor:pointer;transition:border-color 0.15s,background 0.15s;
                  background:var(--studs-panel-bg,#1e1e2e);"
           onmouseover="this.style.borderColor='var(--studs-accent,#6366f1)'"
           onmouseout="this.style.borderColor='var(--studs-border,#3f3f46)'">
        <div style="display:flex;align-items:flex-end;gap:3px;height:40px;margin-bottom:8px;">
          <% [40,65,30,80,55,70].each do |h| %>
            <div style="flex:1;background:var(--studs-accent,#6366f1);opacity:0.75;
                        height:<%= h %>%;border-radius:2px 2px 0 0;"></div>
          <% end %>
        </div>
        <div style="font-size:12px;font-weight:600;color:#e4e4e7;">Bar Chart</div>
        <div style="font-size:10px;color:#71717a;margin-top:2px;">Category comparison</div>
      </div>

      <%# Donut Chart %>
      <div data-action="click->widget-drawer#selectWidget"
           data-widget-type="pie"
           data-widget-label="Donut Chart"
           data-widget-w="3" data-widget-h="3"
           style="border:1px solid var(--studs-border,#3f3f46);border-radius:10px;
                  padding:14px;cursor:pointer;transition:border-color 0.15s,background 0.15s;
                  background:var(--studs-panel-bg,#1e1e2e);"
           onmouseover="this.style.borderColor='var(--studs-accent,#6366f1)'"
           onmouseout="this.style.borderColor='var(--studs-border,#3f3f46)'">
        <div style="display:flex;justify-content:center;height:40px;margin-bottom:8px;">
          <svg viewBox="0 0 42 42" style="width:40px;height:40px;transform:rotate(-90deg);">
            <circle cx="21" cy="21" r="15.9" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="5"/>
            <circle cx="21" cy="21" r="15.9" fill="none" stroke="#60a5fa" stroke-width="5"
                    stroke-dasharray="40 60"/>
            <circle cx="21" cy="21" r="15.9" fill="none" stroke="#34d399" stroke-width="5"
                    stroke-dasharray="25 75" stroke-dashoffset="-40"/>
          </svg>
        </div>
        <div style="font-size:12px;font-weight:600;color:#e4e4e7;">Donut Chart</div>
        <div style="font-size:10px;color:#71717a;margin-top:2px;">Proportion breakdown</div>
      </div>

      <%# Stat Card %>
      <div data-action="click->widget-drawer#selectWidget"
           data-widget-type="stat"
           data-widget-label="Stat Card"
           data-widget-w="2" data-widget-h="2"
           style="border:1px solid var(--studs-border,#3f3f46);border-radius:10px;
                  padding:14px;cursor:pointer;transition:border-color 0.15s,background 0.15s;
                  background:var(--studs-panel-bg,#1e1e2e);"
           onmouseover="this.style.borderColor='var(--studs-accent,#6366f1)'"
           onmouseout="this.style.borderColor='var(--studs-border,#3f3f46)'">
        <div style="text-align:center;height:40px;display:flex;flex-direction:column;
                    align-items:center;justify-content:center;margin-bottom:8px;">
          <div style="font-size:22px;font-weight:700;color:#f4f4f5;line-height:1;">24</div>
          <div style="font-size:9px;color:#71717a;">hours</div>
        </div>
        <div style="font-size:12px;font-weight:600;color:#e4e4e7;">Stat Card</div>
        <div style="font-size:10px;color:#71717a;margin-top:2px;">Single KPI</div>
      </div>

      <%# Progress Bar %>
      <div data-action="click->widget-drawer#selectWidget"
           data-widget-type="progress"
           data-widget-label="Progress Bar"
           data-widget-w="3" data-widget-h="2"
           style="border:1px solid var(--studs-border,#3f3f46);border-radius:10px;
                  padding:14px;cursor:pointer;transition:border-color 0.15s,background 0.15s;
                  background:var(--studs-panel-bg,#1e1e2e);"
           onmouseover="this.style.borderColor='var(--studs-accent,#6366f1)'"
           onmouseout="this.style.borderColor='var(--studs-border,#3f3f46)'">
        <div style="height:40px;display:flex;flex-direction:column;
                    justify-content:center;margin-bottom:8px;">
          <div style="background:rgba(255,255,255,0.08);border-radius:999px;
                      height:8px;overflow:hidden;">
            <div style="background:var(--studs-accent,#6366f1);width:72%;
                        height:100%;border-radius:999px;"></div>
          </div>
          <div style="font-size:10px;font-weight:700;color:var(--studs-accent,#6366f1);
                      text-align:right;margin-top:3px;">72%</div>
        </div>
        <div style="font-size:12px;font-weight:600;color:#e4e4e7;">Progress Bar</div>
        <div style="font-size:10px;color:#71717a;margin-top:2px;">Goal vs. actual</div>
      </div>

      <%# Area Chart %>
      <div data-action="click->widget-drawer#selectWidget"
           data-widget-type="area"
           data-widget-label="Area Chart"
           data-widget-w="4" data-widget-h="3"
           style="border:1px solid var(--studs-border,#3f3f46);border-radius:10px;
                  padding:14px;cursor:pointer;transition:border-color 0.15s,background 0.15s;
                  background:var(--studs-panel-bg,#1e1e2e);"
           onmouseover="this.style.borderColor='var(--studs-accent,#6366f1)'"
           onmouseout="this.style.borderColor='var(--studs-border,#3f3f46)'">
        <svg viewBox="0 0 60 30" style="width:100%;height:40px;margin-bottom:8px;">
          <path d="M4,24 L14,18 L24,20 L34,12 L44,15 L56,5 L56,28 L4,28 Z"
                fill="var(--studs-accent,#6366f1)" opacity="0.25"/>
          <polyline points="4,24 14,18 24,20 34,12 44,15 56,5"
                    fill="none" stroke="var(--studs-accent,#6366f1)"
                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div style="font-size:12px;font-weight:600;color:#e4e4e7;">Area Chart</div>
        <div style="font-size:10px;color:#71717a;margin-top:2px;">Cumulative trend</div>
      </div>

      <%# Heatmap — full width %>
      <div data-action="click->widget-drawer#selectWidget"
           data-widget-type="heatmap"
           data-widget-label="Activity Heatmap"
           data-widget-w="6" data-widget-h="3"
           style="border:1px solid var(--studs-border,#3f3f46);border-radius:10px;
                  padding:14px;cursor:pointer;transition:border-color 0.15s,background 0.15s;
                  background:var(--studs-panel-bg,#1e1e2e);grid-column:span 2;"
           onmouseover="this.style.borderColor='var(--studs-accent,#6366f1)'"
           onmouseout="this.style.borderColor='var(--studs-border,#3f3f46)'">
        <svg viewBox="0 0 210 24" style="width:100%;height:24px;margin-bottom:8px;">
          <% rng_state = 7
             rng = ->(s) { (s * 16807) % 2147483647 }
             26.times do |w|
               4.times do |d|
                 rng_state = rng.(rng_state)
                 r = rng_state.to_f / 2147483647
                 level = r > 0.85 ? 4 : r > 0.70 ? 3 : r > 0.50 ? 2 : r > 0.30 ? 1 : 0
                 op = [0.06, 0.25, 0.45, 0.65, 0.90][level] %>
            <rect x="<%= w*8+1 %>" y="<%= d*5+1 %>"
                  width="6" height="4" rx="1"
                  fill="var(--studs-accent,#6366f1)" opacity="<%= op %>"/>
          <%   end
             end %>
        </svg>
        <div style="font-size:12px;font-weight:600;color:#e4e4e7;">Activity Heatmap</div>
        <div style="font-size:10px;color:#71717a;margin-top:2px;">Calendar-style activity grid</div>
      </div>

    </div><%# /grid %>

    <%# Footer %>
    <div style="padding:12px 20px;border-top:1px solid var(--studs-border,#3f3f46);
                text-align:center;flex-shrink:0;">
      <p style="font-size:11px;color:#52525b;">Widgets are draggable &amp; resizable</p>
    </div>

  </div><%# /panel %>

</div><%# /controller root %>
