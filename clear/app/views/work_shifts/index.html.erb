<% content_for :page_title, "Work Shifts" %>
<% content_for :page_subtitle, "Your work schedule" %>
<style>
  .shift-row { transition: background-color 0.15s ease; }
  .shift-row:hover { background-color: var(--studs-panel-hover); }
</style>
<div class="rounded-2xl p-6" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <%= form_with url: work_shifts_path,
                method: :get,
                data: {
                  turbo_frame: "work_shifts_list",
                  controller: "search",
                  search_form_target: "form"
                } do |f| %>
    <div class="flex items-center justify-between gap-4 mb-5">
      <div class="text-lg font-semibold text-zinc-100">Work Shifts</div>
      <div class="flex items-center gap-1.5">
        <%= render Studs::SearchBarComponent.new(
              class_name: "w-72",
              placeholder: "Search shifts…",
              value: params[:q],
              data: {
                search_target: "input",
                action: "input->search#search keydown->search#submit"
              }
            ) %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to new_work_shift_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          New shift
        <% end %>
      </div>
    </div>
  <% end %>
  <%= turbo_frame_tag "work_shifts_list" do %>
    <div class="overflow-hidden rounded-2xl"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <% if @work_shifts.any? %>
        <% @work_shifts.each_with_index do |shift, i| %>
          <% color = shift.color.presence || "#34D399" %>
          <div class="shift-row flex items-start justify-between gap-4 p-4"
               style="border-left: 4px solid <%= color %>;
                      <%= i > 0 ? "border-top: 1px solid var(--studs-divider);" : "" %>">
            <div class="min-w-0 flex-1">
              <p class="font-medium text-zinc-100 flex items-center gap-2 flex-wrap">
                <%= link_to shift.title.presence || "(Untitled)", edit_work_shift_path(shift),
                      class: "hover:underline underline-offset-2" %>
                <% if shift.recurring? %>
                  <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold"
                        style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover); color: var(--studs-accent);">
                    ↻ Repeats
                  </span>
                <% end %>
              </p>
              <p class="mt-1 text-sm text-zinc-400">
                <% details = [] %>
                <% details << shift.repeat_days_labels if shift.repeat_days_labels.present? %>
                <% details << shift.formatted_time_range if shift.formatted_time_range.present? %>
                <%= details.join(" • ") %>
              </p>
              <% if shift.location.present? %>
                <p class="mt-0.5 text-sm text-zinc-500"><%= shift.location %></p>
              <% end %>
              <% if shift.recurring? && shift.repeat_until.present? %>
                <p class="mt-0.5 text-xs text-zinc-500">Until <%= shift.repeat_until.strftime("%b %d, %Y") %></p>
              <% end %>
            </div>
            <div class="flex shrink-0 items-center gap-2">
              <%= link_to edit_work_shift_path(shift), class: "studs-nav-btn" do %>Edit<% end %>
              <%= button_to "Delete",
                    work_shift_path(shift),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this shift?" } },
                    class: "inline-flex items-center justify-center rounded-xl px-3 py-2 text-sm font-medium
                            border border-red-500/40 text-red-200 hover:bg-red-950/40 transition" %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="p-6 text-sm text-zinc-400">
          <% if @q.present? %>
            No shifts matching "<%= @q %>".
          <% else %>
            No shifts yet. Add your first work shift!
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>