<div class="flex flex-col gap-1 p-3 rounded-2xl" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
  <div class="flex items-center gap-2">
    <span class="text-sm font-semibold text-zinc-100"><%= project_message.user.email %></span>
    <span class="text-xs text-zinc-500"><%= project_message.created_at.strftime("%-I:%M %p") %></span>
  </div>
  <p class="text-sm text-zinc-300"><%= project_message.body %></p>
</div>