<div class="relative overflow-hidden">

  <div>
    <section class="relative">
      <div class="relative border-y" style="border-color: var(--studs-border);">
        <div class="relative h-[calc(100vh-4.5rem)]">
          <%= image_tag "Preview.gif", alt: "Clear app preview", class: "h-full w-full object-cover" %>
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-black/10 via-black/24 to-black/72"></div>

          <div class="absolute inset-x-0 mx-auto w-full max-w-7xl px-6"
               style="bottom: 10%;">
            <h1 class="max-w-[14ch] text-[clamp(2rem,4.6vw+0.4rem,5.2rem)] font-semibold leading-[0.98] tracking-tight text-zinc-50">
              <span class="block">Life is uncertain.</span>
              <span class="block whitespace-nowrap">Your plan shouldn&rsquo;t be.</span>
            </h1>
            <p class="mt-[clamp(0.75rem,1.6vh,1.25rem)] whitespace-nowrap text-[clamp(0.92rem,0.65vw+0.62rem,1.22rem)] leading-relaxed text-zinc-100/95">
              Plan with AI, test in drafts, and collaborate in real time with confidence.
            </p>

            <div class="mt-[clamp(1rem,2.8vh,1.8rem)] flex flex-wrap items-center gap-3">
              <% if user_signed_in? %>
                <%= link_to "Go to dashboard",
                      authenticated_root_path,
                      class: "studs-btn-accent rounded-xl px-5 py-2.5 text-sm" %>

                <%= button_to "Sign out",
                      destroy_user_session_path,
                      method: :delete,
                      data: { turbo: false },
                      class: "studs-nav-btn rounded-xl px-5 py-2.5 text-sm !bg-zinc-900/60 !text-zinc-100" %>
              <% else %>
                <%= link_to "Get Started For Free",
                      new_user_registration_path,
                      data: { turbo: false },
                      class: "studs-btn-accent rounded-xl px-5 py-2.5 text-sm" %>

                <%= link_to "Login",
                      new_user_session_path,
                      data: { turbo: false },
                      class: "studs-nav-btn rounded-xl px-4 py-2 text-sm" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <div class="mx-auto w-full max-w-7xl px-6 pb-24 pt-0">
    <section class="mt-14 space-y-7 sm:mt-20">
      <div class="space-y-2">
        <p class="text-3xl font-semibold tracking-tight text-zinc-100 sm:text-4xl">A Planner for College Students by College Students</p>
      </div>

      <% features = [
        {
          title: "Plan Easily",
          body: "Simplicity is our philosophy. There is no clutter or learning curve. Everything you need is right where you expect it."
        },
        {
          title: "Plan Fast",
          body: "Tired of schedululing your class times or assignments each time on your planner? Our syllabus parser can take care of that in seconds."
        },
        {
          title: "Plan Ahead",
          body: "Stay ahead of deadlines. Our AI prepares study sessions before exams and assignment due dates, so you can stay on track without cramming."
        },
        {
          title: "Plan Together",
          body: "Whether it's group projects or a hobby together, collaborate with your classmates in one shared space without any hassle."
        },
        {
          title: "Plan Beyond",
          body: "Life happens. Plans change. Use our draft system to make alternative schedules as backups when life gets unpredictable."
        }
      ] %>

      <div class="space-y-10 sm:space-y-18">
        <% features.each_with_index do |feature, index| %>
          <article class="group grid gap-6 rounded-[1.75rem] p-5 backdrop-blur-xl transition-all duration-300 sm:p-6 <%= index.odd? ? 'lg:grid-cols-[1.1fr_0.9fr]' : 'lg:grid-cols-[0.9fr_1.1fr]' %> lg:items-center lg:gap-8"
                   style="border: 1px solid color-mix(in srgb, var(--studs-border) 55%, var(--studs-accent) 45%); background-color: color-mix(in srgb, var(--studs-panel-hover) 94%, var(--studs-panel-bg-2) 6%);">
            <div class="<%= index.odd? ? 'lg:order-2' : '' %>">
              <h3 class="text-3xl font-semibold tracking-tight text-zinc-50 sm:text-4xl"><%= feature[:title] %></h3>
              <p class="mt-3 max-w-xl text-base leading-relaxed text-zinc-100/95 sm:text-lg"><%= feature[:body] %></p>
            </div>

            <div class="<%= index.odd? ? 'lg:order-1' : '' %>">
              <div class="overflow-hidden rounded-2xl shadow-xl shadow-black/35" style="border: 1px solid var(--studs-border); background-color: #09090b;">
                <%= image_tag "Preview.gif", alt: "Feature GIF placeholder", class: "h-52 w-full object-cover sm:h-72" %>
              </div>
              <p class="mt-2 text-xs text-zinc-400">GIF placeholder for this feature section</p>
            </div>
          </article>
        <% end %>
      </div>
    </section>

    <section class="mt-20 sm:mt-24">
      <div class="text-center">
        <h3 class="text-4xl font-semibold tracking-tight text-zinc-50 sm:text-5xl lg:text-6xl">
          <span class="block">Deadlines move fast.</span>
          <span class="mt-3 block">Get your schedule on track today.</span>
        </h3>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <% if user_signed_in? %>
            <%= link_to "Go to dashboard",
                  authenticated_root_path,
                  class: "studs-btn-accent rounded-xl px-5 py-2.5 text-sm" %>
          <% else %>
            <%= link_to "Get Started For Free",
                  new_user_registration_path,
                  data: { turbo: false },
                  class: "studs-btn-accent rounded-xl px-5 py-2.5 text-sm" %>
          <% end %>
        </div>
      </div>
    </section>
  </div>
</div>
