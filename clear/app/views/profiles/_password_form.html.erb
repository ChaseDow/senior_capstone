<%= turbo_frame_tag "profile_modal",
      data: {
        modal_target: "frame",
        action: "turbo:frame-load->modal#frameLoaded turbo:submit-end->modal#submitEnded"
      } do %>
  <div class="p-5">
    <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5">
      <div class="space-y-4">
        <div>
          <h2 class="text-lg font-semibold text-zinc-50">Change password</h2>
          <p class="mt-1 text-sm text-zinc-500">Choose a new password for your account.</p>
        </div>

        <%= form_with model: user,
              url: update_password_profile_path,
              method: :patch,
              data: { turbo_frame: "profile_modal" } do |f| %>
          <% label_classes = "block text-[10px] font-bold uppercase tracking-widest mb-1.5" %>
          <% label_style = "color: color-mix(in srgb, var(--studs-accent) 80%, white 20%); opacity: 0.95;" %>
          <% input_classes = "mt-2 w-full rounded-2xl px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border" %>
          <% input_style = "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);" %>

          <% if user.errors.any? %>
            <div class="rounded-xl border border-red-900/40 bg-red-950/30 p-3 text-sm text-red-200">
              <ul class="list-disc pl-5">
                <% user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="space-y-4">
            <div class="relative">
            <%= f.label :current_password, "Current password", class: label_classes, style: label_style %>
            <%= f.password_field :current_password,
                id: "current-password",
                autocomplete: "current-password",
                class: input_classes,
                style: input_style,
                placeholder: "your current password" %>

            <button type="button"
              data-password-toggle
              data-target="current-password"
              class="absolute right-3 top-[calc(50%+1rem)] -translate-y-1/2
                    rounded-md p-1 text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60 studs-eye-toggle
                    focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition">

              <span data-show>
                <%= icon "eye-stroke-rounded", class: "h-5 w-5 studs-icon-accent-soft" %>
              </span>

              <span data-hide class="hidden">
                <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 studs-icon-accent-soft" %>
              </span>
            </button>
            </div>

            <div class="relative">
              <%= f.label :password, "New password", class: label_classes, style: label_style %>
              <%= f.password_field :password,
                    id: "new-password",
                    autocomplete: "new-password",
                    class: input_classes,
                    style: input_style,
                    placeholder: "your new password" %>
              <button type="button"
                data-password-toggle
                data-target="new-password"
                class="absolute right-3 top-[calc(50%+1rem)] -translate-y-1/2 rounded-md p-1 text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60 studs-eye-toggle focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition">
                <span data-show>
                  <%= icon "eye-stroke-rounded", class: "h-5 w-5 studs-icon-accent-soft" %>
                </span>
                <span data-hide class="hidden">
                  <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 studs-icon-accent-soft" %>
                </span>
              </button>
            </div>

            <div class="relative">
              <%= f.label :password_confirmation, "Confirm new password", class: label_classes, style: label_style %>
              <%= f.password_field :password_confirmation,
                    id: "confirm-password",
                    autocomplete: "new-password",
                    class: input_classes,
                    style: input_style,
                    placeholder: "re-type new password" %>

              <button type="button"
                data-password-toggle
                data-target="confirm-password"
                class="absolute right-3 top-[calc(50%+1rem)] -translate-y-1/2 rounded-md p-1 text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60 studs-eye-toggle focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition">
                <span data-show>
                  <%= icon "eye-stroke-rounded", class: "h-5 w-5 studs-icon-accent-soft" %>
                </span>
                <span data-hide class="hidden">
                  <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 studs-icon-accent-soft" %>
                </span>
              </button>
            </div>

            <%= f.submit "Update password",
                  class: "studs-btn-accent !mt-2 !w-full !justify-center !rounded-xl !py-2.5 !text-sm" %>

            <%= link_to profile_path,
                  data: { turbo_frame: "profile_modal", turbo_prefetch: false },
                  class: "studs-nav-btn !w-full !justify-center !rounded-xl !py-2.5 !text-sm" do %>
              Cancel
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
