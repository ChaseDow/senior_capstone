<%= turbo_frame_tag "profile_modal",
      data: {
        modal_target: "frame",
        action: "turbo:frame-load->modal#frameLoaded turbo:submit-end->modal#submitEnded"
      } do %>
  <div class="flex max-h-[85vh] flex-col" data-controller="avatar-crop">
    <!-- Header -->
    <div class="flex items-start justify-between border-b border-zinc-800 bg-zinc-950/50 px-6 py-4">
      <div>
        <div class="text-sm font-semibold text-zinc-100">Change Icon</div>
        <div class="text-xs text-zinc-500">Upload and crop your new avatar</div>
      </div>

      <div class="flex items-center gap-4">
        <div class="h-16 w-16 overflow-hidden rounded-full bg-zinc-900 ring-2" style="--tw-ring-color: var(--studs-border);">
          <!-- LIVE PREVIEW TARGET (must be inside the controller) -->
          <div data-avatar-crop-target="preview" class="h-full w-full"></div>
        </div>

        <div>
          <div class="text-sm font-semibold text-zinc-100">Preview</div>
          <div class="text-xs text-zinc-500">This is how your avatar will look.</div>
        </div>
      </div>

      <button
        type="button"
        data-action="modal#close"
        class="studs-nav-btn">
        ✕
      </button>
    </div>

    <!-- Body -->
    <div class="min-h-0 flex-1 overflow-y-auto p-6 space-y-4">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 space-y-4">
        <% label_classes = "block text-[10px] font-bold uppercase tracking-widest mb-1.5" %>
        <% label_style = "color: color-mix(in srgb, var(--studs-accent) 80%, white 20%); opacity: 0.95;" %>

        <%= form_with model: current_user,
              url: update_avatar_profile_path,
              method: :patch,
              html: { multipart: true },
              data: { avatar_crop_target: "form", action: "submit->avatar-crop#submitCropped" } do |f| %>

          <div class="space-y-3">
            <div class="<%= label_classes %>" style="<%= label_style %>">Upload image</div>

            <%= f.file_field :avatar,
                  id: "avatar-upload-input",
                  accept: "image/*",
                  data: { action: "change->avatar-crop#fileChanged", avatar_crop_target: "file" },
                  class: "sr-only" %>

            <label for="avatar-upload-input"
                   class="studs-nav-btn !inline-flex !rounded-xl !px-4 !py-2 !text-sm">
              Choose file
            </label>

            <!-- Crop area -->
            <div class="rounded-2xl border border-zinc-800 bg-zinc-950/30 p-3">
              <div class="mb-2 flex items-center justify-between">
                <div class="<%= label_classes %>" style="<%= label_style %>">Crop</div>

                <div class="flex gap-2">
                  <button type="button"
                    data-action="avatar-crop#zoomIn"
                    class="studs-nav-btn">
                    +
                  </button>

                  <button type="button"
                    data-action="avatar-crop#zoomOut"
                    class="studs-nav-btn">
                    −
                  </button>

                  <button type="button"
                    data-action="avatar-crop#reset"
                    class="studs-nav-btn">
                    Reset
                  </button>
                </div>
              </div>

              <div class="relative h-[460px] w-full overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900/40">
                <% if current_user.avatar.attached? %>
                  <img
                    data-avatar-crop-target="image"
                    src=""
                    class="hidden block max-w-none select-none"
                    alt="" />
                <% else %>
                  <img
                    data-avatar-crop-target="image"
                    src=""
                    class="hidden"
                    alt="" />
                  <div class="flex h-full items-center justify-center text-sm text-zinc-500">
                    Choose an image to begin
                  </div>
                <% end %>
              </div>

              <div class="mt-2 text-[11px] text-zinc-500">
                Tip: drag to position, resize the square, then Save.
              </div>
            </div>

            <div class="pt-2 space-y-2">
              <button type="submit" class="studs-btn-accent !w-full !justify-center !rounded-xl !py-2.5 !text-sm">
                Save Avatar
              </button>
              <%= link_to "Cancel",
                    profile_path,
                    data: { turbo_frame: "profile_modal", turbo_prefetch: false },
                    class: "studs-nav-btn !w-full !justify-center !rounded-xl !py-2.5 !text-sm" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
