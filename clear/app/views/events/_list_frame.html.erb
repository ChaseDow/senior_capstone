<!-- Searchable list in a turbo frame -->
<%= turbo_frame_tag "events_list" do %>
  <div class="overflow-hidden rounded-2xl"
       style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
    <% occurrences = events || [] %>
    <% if occurrences.any? %>
      <% occurrences.each_with_index do |occ, i| %>
        <% event     = occ.respond_to?(:event) ? occ.event : occ %>
        <% starts_at = occ.respond_to?(:starts_at) ? occ.starts_at : event.starts_at %>
        <% ends_at   = occ.respond_to?(:ends_at)   ? occ.ends_at   : event.ends_at %>
        <!-- For drafted events -->
        <% draft_status = occ.respond_to?(:draft_status) ? occ.draft_status : nil %>
        <% draft_change_index = occ.respond_to?(:draft_change_index) ? occ.draft_change_index : nil %>
        <% is_draft_created = draft_status == "created" %>
        <% is_draft_updated = draft_status == "updated" %>
        <% is_draft_deleted = draft_status == "deleted" %>
        <% restore_path = draft_change_index.present? ? restore_draft_change_path(
             index: draft_change_index,
             start_date: params[:start_date]
           ) : nil %>
        <% draft_edit_path =
             if is_draft_created
               new_event_path(
                 start_time: starts_at,
                 start_date: params[:start_date],
                 source: "draft_changes",
                 temp_id: event.id
               )
             elsif is_draft_updated
               edit_event_path(
                 event,
                  start_date: params[:start_date],
                 source: "draft_changes"
               )
             end %>
        <% operation_label =
            if is_draft_created
              "NEW"
            elsif is_draft_updated
              "EDITED"
            elsif is_draft_deleted
              "REMOVED"
            end %>
        <% operation_label_class =
            if is_draft_created
              "bg-amber-400/90 text-black/90"
            elsif is_draft_updated
              "bg-sky-400/90 text-black/90"
            elsif is_draft_deleted
              "bg-red-400/90 text-white"
            end %>
        <% color = event.color.presence || "#34D399" %>
        <div class="event-row flex items-start justify-between gap-4 p-4"
             style="border-left: 4px solid <%= color %>;
                    <%= is_draft_deleted ? "opacity: 0.55; box-shadow: inset 0 0 0 1px var(--studs-border);" : "" %>
                    <%= i > 0 ? "border-top: 1px solid var(--studs-divider);" : "" %>">
          <div class="min-w-0 flex-1">
            <p class="font-medium text-zinc-100 flex items-center gap-2 flex-wrap">
              <% if is_draft_created %>
                <span><%= event.title.presence || "(Untitled)" %></span>
              <% else %>
                <%= link_to event.title.presence || "(Untitled)", event_path(event, start_date: starts_at&.to_date),
                      class: "hover:underline underline-offset-2",
                      data: { turbo_frame: "_top", turbo_prefetch: false } %>
              <% end %>
              <% if operation_label.present? %>
                <span class="shrink-0 rounded-full px-2 py-0.5 text-[10px] font-semibold <%= operation_label_class %>">
                  <%= operation_label %>
                </span>
              <% end %>
              <% if event.respond_to?(:project_id) && event.project_id.present? %>
                <%= Project.find(event.project_id).title %>
              <% end %>
              <% if event.respond_to?(:recurring?) && event.recurring? %>
                <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold"
                      style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover); color: var(--studs-accent);">
                  ↻ Repeats
                </span>
              <% end %>
              <% if event.respond_to?(:priority) && event.priority.present? %>
                <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold bg-zinc-800 text-zinc-300">
                  P<%= event.priority %>
                </span>
              <% end %>
            </p>
            <p class="mt-1 text-sm text-zinc-400">
              <%= starts_at&.strftime("%b %d, %Y • %I:%M %p") %>
              <% if ends_at.present? %>
                – <%= ends_at.strftime("%I:%M %p") %>
              <% end %>
            </p>
            <% if event.location.present? %>
              <p class="text-sm text-zinc-500">📍 <%= event.location %></p>
            <% end %>
            <% if event.respond_to?(:recurring?) && event.recurring? && event.repeat_until.present? %>
              <p class="mt-1 text-xs text-zinc-500">
                Until <%= event.repeat_until.strftime("%b %d, %Y") %>
              </p>
            <% end %>
          </div>
          <% if is_draft_deleted && restore_path.present? %>
            <div class="flex shrink-0 items-center gap-1.5">
              <%= button_to restore_path,
                    method: :patch,
                    class: "studs-nav-btn",
                    style: "border-color: rgba(34,197,94,0.45); color: #86efac;" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 14l-5-5m0 0l5-5M4 9h9a7 7 0 110 14h-1"/>
                </svg>
                Restore
              <% end %>
            </div>
          <% elsif is_draft_created || is_draft_updated %>
            <div class="flex shrink-0 items-center gap-1.5">
              <%= link_to draft_edit_path,
                    class: "studs-nav-btn",
                    data: { turbo_frame: "_top", turbo_prefetch: false } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit
              <% end %>
              <% if restore_path.present? %>
                <%= button_to restore_path,
                      method: :patch,
                      class: "studs-nav-btn",
                      style: "border-color: rgba(34,197,94,0.45); color: #86efac;" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 14l-5-5m0 0l5-5M4 9h9a7 7 0 110 14h-1"/>
                  </svg>
                  Restore
                <% end %>
              <% end %>
              <% if is_draft_updated %>
                <%= button_to event_path(event, start_date: params[:start_date]),
                      method: :delete,
                      form: { data: { turbo_confirm: "Delete this event?", turbo_frame: "_top" } },
                      class: "studs-nav-btn",
                      style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                  Delete
                <% end %>
              <% end %>
            </div>
          <% else %>
            <div class="flex shrink-0 items-center gap-1.5">
              <%= link_to edit_event_path(event, source: "events_index"),
                    class: "studs-nav-btn",
                    data: { turbo_frame: "_top" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit
              <% end %>
              <%= button_to event_path(event),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this event?", turbo_frame: "_top" } },
                    class: "studs-nav-btn",
                    style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="mb-3 text-4xl opacity-30">📅</div>
        <% if q.present? %>
          <p class="text-sm font-medium text-zinc-300">No events match "<%= q %>"</p>
          <p class="mt-1 text-xs text-zinc-500">Try a different search term</p>
        <% else %>
          <p class="text-sm font-medium text-zinc-300">No events yet</p>
          <p class="mt-1 text-xs text-zinc-500">Create your first event to get started</p>
          <div class="mt-4">
            <%= link_to new_event_path(source: "events_index"),
                  class: "studs-nav-btn",
                  data: { turbo_frame: "_top" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
              New event
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
  <% if pagy&.pages.to_i > 1 %>
    <% pages = pagy.pages %>
    <% page = pagy.page %>
    <% prev_page = page > 1 ? page - 1 : nil %>
    <% next_page = page < pages ? page + 1 : nil %>
    <div class="flex items-center justify-between px-4 py-3 mt-2">
      <p class="text-xs text-zinc-500">Page <%= page %> of <%= pages %></p>
      <div class="flex items-center gap-1.5">
        <%= link_to "← Prev",
              (prev_page ? events_path(page: prev_page) : "#"),
              class: ["studs-nav-btn", prev_page ? "" : "opacity-40 pointer-events-none"].join(" ") %>
        <% ([page - 2, 1].max..[page + 2, pages].min).each do |p| %>
          <%= link_to p, events_path(page: p),
                class: ["studs-nav-btn", p == page ? "font-bold" : ""].join(" ") %>
        <% end %>
        <%= link_to "Next →",
              (next_page ? events_path(page: next_page) : "#"),
              class: ["studs-nav-btn", next_page ? "" : "opacity-40 pointer-events-none"].join(" ") %>
      </div>
    </div>
  <% end %>
<% end %>
