<% content_for :page_title, "Events" %>
<% content_for :page_subtitle, "Upcoming and past events" %>
<style>
  .event-row { transition: background-color 0.15s ease; }
  .event-row:hover { background-color: var(--studs-panel-hover); }

  .events-shell {
    border: 1px solid var(--studs-border);
    background-color: var(--studs-panel-bg);
    box-shadow: none;
  }

  .events-shell-draft {
    border: 1px solid rgba(252,211,77,0.65);
    box-shadow: 0 0 0 1px rgba(251,191,36,0.26);
  }
</style>
<%= render "draft/banner", start_date: (params[:start_date].presence || Date.current.iso8601), active_draft: @draft %>
<div class="events-shell <%= "events-shell-draft" if @draft.present? %> rounded-2xl p-6">
  <!-- Header with search -->
  <%= form_with url: events_path,
                method: :get,
                data: {
                  turbo_frame: "events_list",
                  controller: "search",
                  search_target: "form"
                } do |f| %>
    <div class="flex items-center justify-between gap-4 mb-5">
      <div class="text-lg font-semibold text-zinc-100">Events</div>
      <div class="flex items-center gap-1.5">
        <%= render Studs::SearchBarComponent.new(
              class_name: "w-72",
              placeholder: "Search events…",
              value: params[:q],
              data: {
                search_target: "input",
                action: "input->search#search keydown->search#submit"
              }
            ) %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to destroy_all_events_path,
              class: "studs-nav-btn",
              style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;",
              data: { turbo_method: :delete, turbo_confirm: "Delete all events? This cannot be undone." } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete all
        <% end %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to university_calendar_preview_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Import from University Calendar
        <% end %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to new_event_path(source: "events_index"), class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          New event
        <% end %>
      </div>
    </div>
  <% end %>
  <%= render "events/list_frame", events: (@occurrences || @events || []), q: @q, pagy: @pagy %>
</div>
